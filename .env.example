# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# AI
GEMINI_API_KEY=your_gemini_api_key

# Payments (Paddle) - web only. The Android build ships free, no billing.
PADDLE_WEBHOOK_SECRET=your_paddle_webhook_secret
# Paddle.js client-side token (browser checkout; NOT the API key / webhook secret)
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=your_paddle_client_token
# Paddle environment: 'production' or 'sandbox'
NEXT_PUBLIC_PADDLE_ENV=production
# Paddle Billing price IDs (read by src/lib/billing.ts and the checkout)
NEXT_PUBLIC_PADDLE_SUB_PRICE_ID=your_paddle_subscription_price_id
NEXT_PUBLIC_PADDLE_PACK_PRICE_ID=your_paddle_pack_price_id

# Public site URL (used for OAuth redirects)
NEXT_PUBLIC_SITE_URL=https://www.unicornapps.app

# Gemini rate limiter (item 21). Plain server env (NOT NEXT_PUBLIC_) so they are
# read at runtime and tunable in Vercel without a rebuild. Defaults are applied
# when unset/invalid; these are conservative starting points for the ~10-15 RPM
# shared free-tier ceiling — confirm your project's real RPM/RPD in Google AI
# Studio and tune. Global caps sit below Google's ceiling (429 locally before
# Google does); per-user caps sit below global (fairness for paying users).
RATE_LIMIT_GLOBAL_RPM=8
RATE_LIMIT_GLOBAL_RPD=1200
RATE_LIMIT_USER_RPM=4
RATE_LIMIT_USER_RPD=100
