<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 15 forces edge-to-edge on apps targeting SDK 35, which would
         draw the WebView under the transparent status/navigation bars. The
         web layer is not inset-aware yet (Capacitor 6), so opt out to keep
         the exact pre-35 rendering. Remove when migrating to Capacitor 7+
         with proper inset handling — the attribute is deprecated and will
         stop working once SDK 36 becomes the required target. -->
    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <item name="android:windowOptOutEdgeToEdgeEnforcement">true</item>
    </style>

    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash</item>
        <item name="android:windowOptOutEdgeToEdgeEnforcement">true</item>
    </style>
</resources>
